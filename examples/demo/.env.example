# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# DeepSeek API key — used ONLY by the dev-server proxy (POST /api/chat) in
# vite.config.ts, never exposed to the browser bundle.
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Optional overrides (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
