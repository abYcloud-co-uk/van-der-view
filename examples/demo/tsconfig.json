{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["vite/client"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@abycloud-co-uk/van-der-view": ["../../src/index.ts"],
      "@abycloud-co-uk/van-der-view/browser": ["../../src/browser.ts"]
    }
  },
  "include": ["src"]
}
